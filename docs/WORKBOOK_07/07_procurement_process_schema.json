      "tool_title": "Request for Quotation (RFQ)",
      "activity_name": "Vendor Solicitation",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One RFQ issued per procurement category or per vendor. Multiple RFQs may run in parallel for the same category (minimum 3 quotes required for items > GHS 5,000).",
      "notes": "Formal RFQ document sent to vendors. Includes technical specifications and commercial terms. Feeds into D7.4 (Vendor Selection Matrix).",
      "sections": [
        {
          "id": "s1",
          "title": "RFQ Metadata",
          "fields": [
            {
              "name": "rfq_number",
              "label": "RFQ Number",
              "type": "string",
              "required": true,
              "auto_generated": true
            },
            {
              "name": "issued_by",
              "label": "Issued By",
              "type": "string",
              "required": true
            },
            {
              "name": "date_issued",
              "label": "Date Issued",
              "type": "date",
              "required": true
            },
            {
              "name": "quote_submission_deadline",
              "label": "Quote Submission Deadline",
              "type": "date",
              "required": true
            },
            {
              "name": "target_delivery_location",
              "label": "Target Delivery Location",
              "type": "string",
              "required": true
            },
            {
              "name": "required_delivery_date",
              "label": "Required Delivery Date",
              "type": "date",
              "required": true
            }
