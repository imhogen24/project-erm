    {
      "tool_id": "D7.4",
      "tool_title": "Vendor Selection Matrix",
      "activity_name": "Quote Comparison",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One matrix per procurement category. Minimum 3 vendor quotes required for items > GHS 5,000.",
      "notes": "Compares vendor quotes across price, lead time, quality rating, and payment terms. Procurement officer selects the approved vendor. Feeds into D7.5 (Purchase Order).",
      "sections": [
        {
          "id": "s1",
          "title": "Analysis Metadata",
          "fields": [
            {
              "name": "procurement_officer",
              "label": "Procurement Officer",
              "type": "string",
              "required": true
            },
            {
              "name": "analysis_date",
              "label": "Analysis Date",
              "type": "date",
              "required": true
            },
            {
              "name": "reference_rfq",
              "label": "Reference RFQ Number",
              "type": "string",
              "required": true
            },
            {
              "name": "target_item_category",
              "label": "Target Item / Category",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Vendor Comparison",
          "description": "Minimum 3 quotes for items > GHS 5,000",
          "fields": [
            {
              "name": "vendor_comparison",
              "label": "Vendor Quotes",
              "type": "table",
              "columns": [
                {
                  "name": "evaluation_criteria",
                  "label": "Evaluation Criteria",
                  "type": "string"
                },
                {
                  "name": "vendor_a",
                  "label": "Vendor A",
                  "type": "string"
                },
                {
                  "name": "vendor_b",
                  "label": "Vendor B",
                  "type": "string"
                },
                {
                  "name": "vendor_c",
                  "label": "Vendor C",
                  "type": "string"
                }
              ],
              "prefilled_rows": [
                "Vendor Name",
                "Unit Price (GHS)",
                "Total Quote Value (GHS)",
                "Lead Time (Days)",
                "Quality / Brand Rating",
                "Payment Terms",
                "Warranty Offered"
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Vendor Selection Decision",
          "fields": [
            {
              "name": "approved_vendor",
              "label": "Approved Vendor",
              "type": "string",
              "required": true
            },
            {
              "name": "selection_rationale",
              "label": "Selection Rationale",
              "type": "text",
              "required": true
            },
            {
              "name": "approved_total_value_ghs",
              "label": "Approved Total Value (GHS)",
              "type": "currency",
              "required": true
            },
            {
              "name": "head_of_ops_signature",
