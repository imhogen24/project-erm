                },
                {
                  "name": "part_description",
                  "label": "Part Description",
                  "type": "string"
                },
                {
                  "name": "technical_spec",
                  "label": "Technical Specification",
                  "type": "string"
                },
                {
                  "name": "qty_required",
                  "label": "Quantity Required",
                  "type": "number"
                },
                {
                  "name": "preferred_brand_model",
                  "label": "Preferred Brand / Model",
                  "type": "string"
                },
                {
                  "name": "source_type",
                  "label": "Source Type",
                  "type": "enum",
                  "options": [
                    "Buy",
                    "Stock"
