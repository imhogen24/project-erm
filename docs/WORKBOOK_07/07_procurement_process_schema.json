                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "part_number",
                  "label": "Part Number",
                  "type": "string"
                },
                {
                  "name": "part_description",
                  "label": "Part Description",
                  "type": "string"
                },
                {
                  "name": "material_spec",
                  "label": "Material Specification",
                  "type": "string"
                },
                {
                  "name": "dimensions_sizing",
                  "label": "Dimensions / Sizing",
                  "type": "string"
                },
                {
                  "name": "qty_required",
                  "label": "Quantity Required",
                  "type": "number"
                },
                {
                  "name": "uom",
                  "label": "Unit of Measure (UOM)",
                  "type": "string"
                },
                {
                  "name": "source_type",
                  "label": "Source Type",
                  "type": "enum",
                  "options": [
                    "Buy",
                    "Make",
                    "Stock"
