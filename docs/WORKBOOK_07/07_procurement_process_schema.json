    {
      "tool_id": "D7.2",
      "tool_title": "Procurement List & Budget Allocation",
      "activity_name": "Procurement Planning",
      "tier": "both",
      "notes": "Categorizes D7.1 BOM items into procurement categories with budget allocation from D4.8. Flags critical lead time warnings. Triggers RFQ issuance (D7.3) per category.",
      "sections": [
        {
          "id": "s1",
          "title": "Procurement Metadata",
          "fields": [
            {
              "name": "procurement_officer",
              "label": "Procurement Officer",
              "type": "string",
              "required": true
            },
            {
              "name": "date_generated",
              "label": "Date Generated",
              "type": "date",
              "required": true
            },
            {
              "name": "reference_bom",
              "label": "Reference BOM",
              "type": "string",
              "required": true
            },
            {
              "name": "total_allocated_bom_budget_ghs",
              "label": "Total Allocated BOM Budget (GHS)",
              "type": "currency",
              "required": true,
              "inherited_from": "D4.8"
            }
          ]
        },
        {
          "id": "s2",
          "title": "Categorized Procurement & Budget Check",
          "fields": [
            {
              "name": "procurement_categories",
              "label": "Procurement Categories",
              "type": "table",
              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "bom_category",
                  "label": "BOM Category",
                  "type": "string"
                },
                {
                  "name": "total_items",
                  "label": "Total Items",
                  "type": "number"
                },
                {
                  "name": "allocated_budget_ghs",
                  "label": "Allocated Budget (GHS)",
                  "type": "currency"
                },
                {
                  "name": "sourcing_strategy",
                  "label": "Target Sourcing Strategy",
                  "type": "enum",
                  "options": [
                    "Local Purchase",
                    "Import",
                    "Stock Draw",
                    "Fabricate In-house"
                  ]
                },
                {
                  "name": "lead_time_warning",
                  "label": "Critical Lead Time Warning",
                  "type": "boolean"
                }
              ],
              "required": true
            },
            {
              "name": "total_estimated_spend_ghs",
              "label": "Total Estimated Spend (GHS)",
              "type": "currency",
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Approval",
          "fields": [
            {
              "name": "within_budget",
              "label": "Total estimated spend within allocated BOM budget?",
              "type": "boolean",
              "required": true
            },
            {
              "name": "head_of_ops_signature",
              "label": "Head of Operations Signature",
              "type": "signature",
              "required": true
            },
            {
              "name": "date_signed",
              "label": "Date",
              "type": "date",
              "required": true
            }
          ]
        }
      ]
    },
    {
