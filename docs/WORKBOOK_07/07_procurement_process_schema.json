              "label": "Vendor Contact Person",
              "type": "string",
              "required": true
            },
            {
              "name": "vendor_email",
              "label": "Vendor Email",
              "type": "email",
              "required": true
            },
            {
              "name": "vendor_phone",
              "label": "Vendor Phone",
              "type": "string",
              "required": true
            }
