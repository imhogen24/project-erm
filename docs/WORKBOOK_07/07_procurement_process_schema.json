      "sections": [
        {
          "id": "s1",
          "title": "BOM Metadata",
          "fields": [
            {
              "name": "extracted_by",
              "label": "Extracted By (Lead CAD Engineer)",
              "type": "string",
              "required": true
            },
            {
              "name": "extraction_date",
              "label": "Extraction Date",
              "type": "date",
              "required": true
            },
            {
