              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "item_description",
                  "label": "Item Description",
                  "type": "string"
                },
                {
                  "name": "technical_spec",
                  "label": "Technical Specification",
                  "type": "text"
                },
                {
                  "name": "qty_required",
                  "label": "Qty Required",
                  "type": "number"
                },
                {
                  "name": "uom",
                  "label": "UOM",
                  "type": "string"
                },
                {
                  "name": "preferred_brand",
                  "label": "Preferred Brand / Model",
                  "type": "string"
                }
              ],
              "required": true
            }
          ]
        },
