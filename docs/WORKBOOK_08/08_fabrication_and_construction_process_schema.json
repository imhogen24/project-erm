    {
      "tool_id": "D8.5",
      "tool_title": "In-Process QC Log",
      "activity_name": "Dimensional & Structural Check",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One log per inspection point (e.g. Post-Welding, Pre-Paint, Post-Assembly). Any FAIL or REWORK result blocks progression to the next fabrication stage.",
