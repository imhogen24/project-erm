            {
              "name": "ref_drawing",
              "label": "Reference Drawing #",
              "type": "string",
              "required": true
            },
            {
              "name": "traveler_issued_by",
              "label": "Traveler Issued By",
              "type": "string",
              "required": true
            },
            {
              "name": "date_issued",
              "label": "Date Issued",
              "type": "date",
              "required": true
            }
