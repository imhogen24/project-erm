{
  "workbook_id": 8,
  "workbook_name": "Fabrication and Construction Process",
  "tools": [
    {
      "tool_id": "D8.1",
      "tool_title": "Job Process Sheet",
      "activity_name": "Daily Work Order",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One sheet per shift/day. Created by supervisor each morning to allocate tasks across the fabrication team.",
      "sections": [
        {
          "id": "s1",
          "title": "Work Order Metadata",
          "fields": [
            {
              "name": "supervisor",
              "label": "Supervisor",
              "type": "string",
              "required": true
            },
            {
              "name": "date_of_work",
              "label": "Date of Work",
              "type": "date",
              "required": true
            },
            {
              "name": "project_name",
              "label": "Project Name",
              "type": "string",
              "required": true,
              "inherited_from": "D1.3"
            },
            {
              "name": "target_output_for_shift",
              "label": "Target Output for Shift",
              "type": "text",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Task Allocation & Routing",
          "fields": [
            {
              "name": "task_allocation",
              "label": "Shift Tasks",
              "type": "table",
              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "task_description",
                  "label": "Task Description",
                  "type": "text"
                },
                {
                  "name": "ref_drawing",
                  "label": "Reference Drawing #",
                  "type": "string"
                },
                {
                  "name": "assigned_technician",
                  "label": "Assigned Technician / Welder",
                  "type": "string"
                },
                {
                  "name": "required_machinery",
                  "label": "Required Machinery",
                  "type": "string"
                },
                {
                  "name": "allocated_time_hrs",
                  "label": "Allocated Time (Hrs)",
                  "type": "number"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "type": "enum",
                  "options": [
                    "Done",
                    "Pending",
                    "Blocked"
                  ]
                },
                {
                  "name": "supervisor_signoff",
                  "label": "Supervisor Sign-off",
                  "type": "string"
                }
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "End-of-Shift Summary",
          "fields": [
            {
              "name": "target_achieved",
              "label": "Shift target achieved?",
              "type": "boolean",
              "required": true
            },
            {
              "name": "carryover_tasks",
              "label": "Carryover Tasks (if any)",
              "type": "text",
              "required": false
            },
            {
              "name": "supervisor_signature",
              "label": "Supervisor Signature",
              "type": "signature",
              "required": true
            }
          ]
        }
      ]
    },
    {
