              "type": "string",
              "required": true
            },
            {
              "name": "inspection_date",
              "label": "Inspection Date",
              "type": "date",
              "required": true
            },
            {
              "name": "reference_traveler",
              "label": "Reference Traveler",
              "type": "string",
              "required": true
            },
            {
              "name": "fabrication_stage",
              "label": "Fabrication Stage",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Critical Inspection Points",
          "fields": [
            {
              "name": "inspection_points",
              "label": "Dimensional & Structural Checks",
              "type": "table",
              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "inspection_parameter",
