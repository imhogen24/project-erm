                },
                {
                  "name": "required_tools_machinery",
                  "label": "Required Tools / Machinery",
                  "type": "string"
                },
                {
                  "name": "assigned_to",
                  "label": "Assigned To",
                  "type": "string"
                },
                {
                  "name": "date_completed",
                  "label": "Date Completed",
                  "type": "date"
                },
                {
                  "name": "supervisor_signoff",
                  "label": "Supervisor Sign-off",
                  "type": "string"
                }
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Traveler Completion",
          "fields": [
            {
              "name": "all_stages_complete",
              "label": "All routing stages signed off?",
