        {
          "id": "s1",
          "title": "Setup Metadata",
          "fields": [
            {
              "name": "executing_supervisor",
              "label": "Executing Supervisor",
              "type": "string",
              "required": true
            },
            {
              "name": "date_time_of_check",
              "label": "Date & Time of Check",
              "type": "string",
              "required": true
            },
            {
              "name": "project_cell_area",
              "label": "Project / Cell Area",
              "type": "string",
              "required": true
            },
            {
              "name": "shift",
              "label": "Shift",
              "type": "enum",
              "options": [
                "Morning",
                "Afternoon"
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Machinery & Tooling Verification",
          "fields": [
            {
              "name": "tooling_checklist",
              "label": "Equipment Checks",
              "type": "table",
              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "equipment_category",
                  "label": "Equipment Category",
                  "type": "string"
                },
                {
                  "name": "specific_check",
                  "label": "Specific Check Required",
                  "type": "text"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "type": "enum",
                  "options": [
                    "Pass",
                    "Fail",
                    "N/A"
                  ]
                },
                {
                  "name": "corrective_action",
                  "label": "Corrective Action Taken",
                  "type": "text"
                },
                {
                  "name": "checked_by",
                  "label": "Checked By",
                  "type": "string"
                }
              ],
              "prefilled_rows": [
                "Welding Stations \u2014 Shielding gas, electrode, ground clamp",
                "Cutting Equipment \u2014 Blade condition, guard, coolant",
                "Measuring Instruments \u2014 Calibration status",
                "Lifting & Handling \u2014 Sling load rating, hook condition",
                "Work Area \u2014 Clear of hazards, adequate lighting"
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Clearance",
          "fields": [
            {
              "name": "all_checks_pass",
              "label": "All checks passed \u2014 shop floor cleared for shift start?",
              "type": "boolean",
              "required": true
            },
            {
              "name": "supervisor_signature",
              "label": "Supervisor Signature",
              "type": "signature",
              "required": true
            },
            {
              "name": "date_signed",
              "label": "Date",
              "type": "date",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "tool_id": "D8.3",
      "tool_title": "Safety Briefing & PPE Log",
      "activity_name": "Toolbox Talk",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One log per shift briefing. Each technician signs to confirm attendance and PPE compliance before work begins.",
