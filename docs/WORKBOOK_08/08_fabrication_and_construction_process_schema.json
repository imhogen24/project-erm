      "tool_title": "Tooling & Setup Checklist",
      "activity_name": "Pre-Shift Verification",
      "tier": "both",
      "repeating": true,
      "repeat_note": "Completed at the start of each shift before fabrication begins. Any Fail must be resolved before work starts.",
