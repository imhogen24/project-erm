            {
              "name": "supervisor_signature",
              "label": "Supervisor Signature",
              "type": "signature",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "tool_id": "D8.4",
      "tool_title": "Fabrication Routing Traveler",
      "activity_name": "Physical Batch Tracking",
      "tier": "both",
      "repeating": true,
      "repeat_note": "One traveler per batch or major assembly (e.g. Main Chassis Frame). Travels physically with the part through each manufacturing stage. Stages must be signed sequentially.",
