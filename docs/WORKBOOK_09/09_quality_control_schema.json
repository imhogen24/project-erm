{
  "workbook_id": 9,
  "workbook_name": "Quality Control and Testing Process",
  "tools": [
    {
      "tool_id": "D9.1",
      "tool_title": "QA Testing Checklist (Prep)",
      "activity_name": "QA Preparation",
      "tier": "both",
      "notes": "Pre-testing setup verification. Confirms test equipment is calibrated, test plans reference the correct drawings, and the fabricated unit matches the BOM. Must be approved before any testing begins.",
      "sections": [
        {
          "id": "s1",
          "title": "Inspection Prep Metadata",
          "fields": [
            {
              "name": "qa_officer",
              "label": "QA Officer",
              "type": "string",
              "required": true
            },
            {
              "name": "date",
              "label": "Date",
              "type": "date",
              "required": true
            },
            {
              "name": "project_name",
              "label": "Project Name",
              "type": "string",
              "required": true,
              "inherited_from": "D1.3"
            },
            {
              "name": "ref_fabrication_completion",
              "label": "Reference Fabrication Completion Notice",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Pre-Test Checklist",
          "fields": [
            {
              "name": "checklist",
              "label": "Preparation Checks",
              "type": "table",
              "columns": [
                {
                  "name": "sn",
                  "label": "SN",
                  "type": "string"
                },
                {
                  "name": "check_item",
                  "label": "Check Item",
                  "type": "text"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "type": "enum",
                  "options": [
                    "Pass",
                    "Fail",
                    "N/A"
                  ]
                },
                {
                  "name": "notes",
                  "label": "Notes",
                  "type": "text"
                }
              ],
              "prefilled_rows": [
                "Test equipment calibration certificates current",
                "Reference drawings match D6.10 CAD-locked version",
                "Unit serial/batch number recorded",
                "All D8.5 rework items closed",
                "Safety area prepared"
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Sign-off",
          "fields": [
            {
              "name": "ready_for_testing",
              "label": "Unit cleared for QA testing?",
              "type": "boolean",
              "required": true
            },
            {
              "name": "qa_officer_signature",
              "label": "QA Officer Signature",
              "type": "signature",
              "required": true
            },
            {
              "name": "date_signed",
              "label": "Date",
              "type": "date",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "tool_id": "D9.2",
