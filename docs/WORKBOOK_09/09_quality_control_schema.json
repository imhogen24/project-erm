    {
      "tool_id": "D9.5",
      "tool_title": "Non-Conformance Report",
      "activity_name": "NCR Logging",
      "tier": "both",
      "conditional": true,
      "condition": "Raised when any D9.2, D9.3, or D9.4 check returns Fail",
      "sections": [
        {
          "id": "s1",
          "title": "NCR Metadata",
          "fields": [
            {
              "name": "ncr_number",
              "label": "NCR Number",
              "type": "string",
              "required": true,
              "auto_generated": true
            },
            {
              "name": "raised_by",
              "label": "Raised By",
              "type": "string",
              "required": true
            },
            {
              "name": "date_raised",
              "label": "Date Raised",
              "type": "date",
              "required": true
            },
            {
              "name": "source_tool",
              "label": "Source Tool (D9.2 / D9.3 / D9.4)",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Non-Conformance Detail",
          "fields": [
            {
              "name": "description",
              "label": "Description of Non-Conformance",
              "type": "text",
              "required": true
            },
            {
              "name": "affected_feature",
              "label": "Affected Feature / Component",
              "type": "string",
              "required": true
            },
            {
              "name": "severity",
              "label": "Severity",
              "type": "enum",
              "options": [
                "Critical",
                "Major",
                "Minor"
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Disposition",
          "fields": [
            {
              "name": "disposition",
              "label": "Disposition Decision",
              "type": "enum",
              "options": [
                "Rework (D9.6)",
                "Accept as-is with waiver",
                "Scrap"
              ],
              "required": true
            },
            {
              "name": "head_of_engineering_signature",
              "label": "Head of Engineering Signature",
              "type": "signature",
              "required": true
            },
            {
              "name": "date_signed",
              "label": "Date",
              "type": "date",
              "required": true
            }
          ]
        }
      ]
    },
