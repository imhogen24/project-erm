    {
      "tool_id": "MDS.1.4",
      "tool_title": "Hub Synchronization & Confidentiality Sign-off",
      "activity_name": "Marketing Hub Integration",
      "tier": "both",
      "notes": "Final PM review confirming no proprietary client data or background IP is contained in the approved marketing package before it is published to the Marketing Hub. Triggers the publish action.",
      "sections": [
        {
          "id": "s1",
          "title": "Confidentiality Review",
          "fields": [
            {
              "name": "project_manager",
              "label": "Project Manager",
              "type": "string",
              "required": true
            },
            {
              "name": "date",
              "label": "Date",
              "type": "date",
              "required": true
            },
            {
              "name": "ref_visual_manifest",
              "label": "Reference Visual Content Manifest (MDS.1.3)",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "s2",
          "title": "Confidentiality Checklist",
          "fields": [
            {
              "name": "checklist",
              "label": "Pre-Publish Checks",
              "type": "table",
              "columns": [
                {
                  "name": "check_item",
                  "label": "Check Item",
                  "type": "string"
                },
                {
                  "name": "status",
                  "label": "Status",
                  "type": "enum",
                  "options": ["Pass", "Fail", "N/A"]
                },
                {
                  "name": "notes",
                  "label": "Notes",
                  "type": "text"
                }
              ],
              "prefilled_rows": [
                {"check_item": "No client proprietary dimensions or trade secrets visible"},
                {"check_item": "Client name/logo usage approved by client"},
                {"check_item": "No IMHOGEN background IP exposed in published drawings"},
                {"check_item": "All assets watermarked or cropped per policy"},
                {"check_item": "Client consent form (MDS.1.1) on file"}
              ],
              "required": true
            }
          ]
        },
        {
          "id": "s3",
          "title": "Publish Authorization",
          "fields": [
            {
              "name": "all_checks_passed",
              "label": "All confidentiality checks passed?",
              "type": "boolean",
              "required": true
            },
            {
              "name": "project_manager_signature",
              "label": "Project Manager Signature",
              "type": "signature",
              "required": true
            },
